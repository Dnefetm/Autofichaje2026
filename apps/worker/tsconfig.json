{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@gestor/shared": [
                "../../packages/shared"
            ],
            "@gestor/adapters": [
                "../../packages/adapters"
            ],
            "@gestor/sync": [
                "../../packages/sync"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}